# =========
# BUILDER
# =========
FROM node:20-alpine AS builder

RUN apk update && apk add --no-cache libc6-compat

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@8.15.1

# Dependencies
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

RUN pnpm install --frozen-lockfile

# Source code
COPY . .

# Vite requires env vars at build time if they start with VITE_
# For this docker setup, we will configure Nginx to proxy API/Socket requests
# so the frontend will just call its own origin (e.g. '/' instead of 'http://api-server')
# We inject dummy URLs here, or let them be empty so our code falls back to relative paths
ARG VITE_API_URL="/api/v1"
ARG VITE_SOCKET_URL=""
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_SOCKET_URL=$VITE_SOCKET_URL

# Build Web app
RUN pnpm --filter web... build

# =========
# RUNNER
# =========
FROM nginx:alpine AS runner

# Copy built static files to Nginx expected directory
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# Custom Nginx configuration to support SPA routing and API proxy
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
