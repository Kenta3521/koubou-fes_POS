generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  passwordHash  String
  name          String
  status        UserStatus         @default(ACTIVE)
  isSystemAdmin Boolean            @default(false)
  createdAt     DateTime           @default(now())
  auditLogs     AuditLog[]
  cashReports   CashReport[]
  transactions  Transaction[]
  organizations UserOrganization[]
}

model Organization {
  id           String             @id @default(uuid())
  name         String
  inviteCode   String             @unique
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  auditLogs    AuditLog[]
  cashReports  CashReport[]
  categories   Category[]
  discounts    Discount[]
  products     Product[]
  roles        ServiceRole[]
  transactions Transaction[]
  members      UserOrganization[]
}

model UserOrganization {
  userId         String
  organizationId String
  permissions    Json?
  organization   Organization           @relation(fields: [organizationId], references: [id])
  user           User                   @relation(fields: [userId], references: [id])
  roles          UserOrganizationRole[]

  @@id([userId, organizationId])
}

model UserOrganizationRole {
  userId           String
  organizationId   String
  roleId           String
  createdAt        DateTime         @default(now())
  role             ServiceRole      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  userOrganization UserOrganization @relation(fields: [userId, organizationId], references: [userId, organizationId], onDelete: Cascade)

  @@id([userId, organizationId, roleId])
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String?
  category    String
  createdAt   DateTime         @default(now())
  name        String
  roles       RolePermission[]
}

model ServiceRole {
  id             String                 @id @default(uuid())
  organizationId String?
  name           String
  description    String?
  isSystemRole   Boolean                @default(false)
  createdAt      DateTime               @default(now())
  permissions    RolePermission[]
  organization   Organization?          @relation(fields: [organizationId], references: [id])
  userRoles      UserOrganizationRole[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime    @default(now())
  permission   Permission  @relation(fields: [permissionId], references: [id])
  role         ServiceRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Category {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  sortOrder      Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id])
  discounts      Discount[]   @relation("TargetCategory")
  conditionDiscounts Discount[] @relation("ConditionCategory")
  products       Product[]
}

model Product {
  id                String            @id @default(uuid())
  organizationId    String
  categoryId        String?
  name              String
  price             Int
  stock             Int               @default(0)
  isActive          Boolean           @default(true)
  deletedAt         DateTime?
  targetedDiscounts Discount[]        @relation("TargetProduct")
  conditionDiscounts Discount[]       @relation("ConditionProduct")
  category          Category?         @relation(fields: [categoryId], references: [id])
  organization      Organization      @relation(fields: [organizationId], references: [id])
  stockLogs         StockLog[]
  items             TransactionItem[]
}

model StockLog {
  id           String            @id @default(uuid())
  productId    String
  changeAmount Int
  reason       StockChangeReason
  createdAt    DateTime          @default(now())
  product      Product           @relation(fields: [productId], references: [id])
}

model Discount {
  id               String                @id @default(uuid())
  organizationId   String
  name             String
  type             DiscountType
  value            Int
  isActive         Boolean               @default(true)
  conditionType    DiscountConditionType @default(NONE)
  conditionValue   Int                   @default(0)
  priority         Int                   @default(0)
  targetProductId  String?
  targetType       DiscountTargetType    @default(ORDER_TOTAL)
  triggerType      DiscountTriggerType   @default(MANUAL)
  validFrom        DateTime?
  validTo          DateTime?
  targetCategoryId String?
  conditionTargetType DiscountTargetType @default(ORDER_TOTAL)
  conditionProductId  String?
  conditionCategoryId String?
  organization     Organization          @relation(fields: [organizationId], references: [id])
  category         Category?             @relation("TargetCategory", fields: [targetCategoryId], references: [id])
  product          Product?              @relation("TargetProduct", fields: [targetProductId], references: [id])
  conditionCategory Category?            @relation("ConditionCategory", fields: [conditionCategoryId], references: [id])
  conditionProduct  Product?             @relation("ConditionProduct", fields: [conditionProductId], references: [id])
  transactions     Transaction[]
  transactionItems TransactionItem[]
}

model Transaction {
  id                    String            @id @default(uuid())
  organizationId        String
  userId                String
  totalAmount           Int
  discountAmount        Int               @default(0)
  discountId            String?
  paymentMethod         PaymentMethod
  paypayOrderId         String?           @unique
  status                TransactionStatus @default(PENDING)
  createdAt             DateTime          @default(now())
  paypayCodeId          String?           @unique
  stripePaymentIntentId String?           @unique
  discount       Discount?         @relation(fields: [discountId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])
  user           User              @relation(fields: [userId], references: [id])
  items          TransactionItem[]
}

model TransactionItem {
  id                String      @id @default(uuid())
  transactionId     String
  productId         String
  quantity          Int
  unitPrice         Int
  appliedDiscountId String?
  discountAmount    Int         @default(0)
  originalPrice     Int         @default(0)
  discount          Discount?   @relation(fields: [appliedDiscountId], references: [id])
  product           Product     @relation(fields: [productId], references: [id])
  transaction       Transaction @relation(fields: [transactionId], references: [id])
}

model CashReport {
  id               String       @id @default(uuid())
  organizationId   String
  userId           String
  openingCash      Int
  theoreticalSales Int
  actualCash       Int
  difference       Int
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id])
  user             User         @relation(fields: [userId], references: [id])
}

model AuditLog {
  id                  String        @id @default(uuid())
  organizationId      String?
  userId              String
  category            String
  action              String
  targetId            String?
  payload             Json?
  isSystemAdminAction Boolean       @default(false)
  createdAt           DateTime      @default(now())
  organization        Organization? @relation(fields: [organizationId], references: [id])
  user                User          @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([category])
  @@index([userId])
}

model SystemSetting {
  id              String    @id @default("singleton")
  eventDate       DateTime?
  eventStartTime  String?
  eventEndTime    String?
  systemEnabled   Boolean   @default(true)
  paypayEnabled   Boolean   @default(true)
  paypayQrTimeout Int       @default(300)
  tapToPayEnabled Boolean   @default(true)
  stripeLocationId String?
  updatedAt       DateTime  @updatedAt
}

enum DiscountTargetType {
  ORDER_TOTAL
  SPECIFIC_PROD
  CATEGORY
  ALL_PRODUCTS
}

enum DiscountConditionType {
  NONE
  MIN_QUANTITY
  MIN_AMOUNT
}

enum DiscountTriggerType {
  MANUAL
  AUTO
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  PAYPAY
  TAP_TO_PAY
}

enum StockChangeReason {
  SALE
  REPLENISH
  ADJUSTMENT
  RETURN
}

enum DiscountType {
  FIXED
  PERCENT
}
